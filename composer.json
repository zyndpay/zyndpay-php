{
  "name": "zyndpay/zyndpay-php",
  "version": "1.7.2",
  "description": "Official ZyndPay PHP SDK — accept USDT payments with a few lines of code",
  "type": "library",
  "license": "MIT",
  "keywords": ["zyndpay", "crypto", "usdt", "trc20", "payment-gateway"],
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "autoload": {
    "psr-4": {
      "ZyndPay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZyndPay\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "minimum-stability": "stable"
}
